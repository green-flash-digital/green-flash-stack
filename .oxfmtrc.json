{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "**/.turbo/**",
    "**/.wrangler/**",
    "**/dist/**",
    "**/bin/**",
    "**/.store/**",
    "**/.react-router/**",
    "**/.vite-cache/**",
    "**/.yarn/**"
  ],
  "trailingComma": "none",
  "singleQuote": false,
  "tabWidth": 2,
  "useTabs": false,
  "sortImports": {
    "newlinesBetween": true,
    "customGroups": [
      {
        "groupName": "react",
        "elementNamePattern": ["react", "react-**"]
      },
      {
        "groupName": "greenflash",
        "elementNamePattern": ["@greenflash/**"]
      }
    ],
    "groups": ["builtin", "react", "external", "internal", ["sibling", "parent", "index"]]
  }
}
