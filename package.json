{
  "name": "green-flash-stack",
  "version": "1.0.0",
  "private": true,
  "description": "A modern, TypeScript-first technology stack of reusable tools, engines, and developer utilities—maintained in one cohesive monorepo and published as standalone packages",
  "keywords": [
    "build-tools",
    "cli",
    "developer-experience",
    "devtools",
    "dx",
    "ecosystem",
    "framework",
    "green-flash",
    "green-flash-stack",
    "modules",
    "monorepo",
    "nodejs",
    "packages",
    "shared-libraries",
    "toolchain",
    "tooling",
    "typescript",
    "typescript-tools",
    "utilities",
    "workspace"
  ],
  "homepage": "https://github.com/green-flash-digital/green-flash-stack#readme",
  "bugs": {
    "url": "https://github.com/green-flash-digital/green-flash-stack/issues"
  },
  "license": "ISC",
  "author": "Drew DeCarme (drew@greenflash.digital)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/green-flash-digital/green-flash-stack.git"
  },
  "workspaces": {
    "packages": [
      "packages/**"
    ]
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:ci": "turbo run test:ci",
    "format": "oxfmt .",
    "format:check": "oxfmt . --check",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "release": "yarn changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "turbo": "2.10.4",
    "typescript": "6.0.3"
  },
  "packageManager": "yarn@4.17.0"
}
