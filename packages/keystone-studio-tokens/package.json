{
  "name": "@keystone-css/studio-tokens",
  "version": "0.3.6",
  "description": "A standalone package to test the APIs in @keystone-css/core and to establish the tokens for the @keystone-css/studio",
  "homepage": "https://github.com/keystone-css/keystone-css#readme",
  "bugs": {
    "url": "https://github.com/keystone-css/keystone-css/issues"
  },
  "license": "MIT",
  "author": "Drew DeCarme (drew@greenflash.digital)",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/keystone-css/keystone-css.git"
  },
  "type": "module",
  "exports": {
    ".": "./.keystone/index.ts",
    "./ts": "./.keystone/index.ts",
    "./scss": "./dist/scss/_index.scss",
    "./root.css": "./.keystone/_generated/root.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "yarn tsx ./scripts/build-studio-tokens.ts",
    "dev": "yarn tsx ./scripts/dev-studio-tokens.ts"
  },
  "dependencies": {
    "@gfdigital/tsconfig": "0.3.1",
    "typescript": "5.8.3"
  },
  "devDependencies": {
    "@keystone-css/core": "0.3.6",
    "isoscribe": "0.2.0",
    "tsx": "4.19.4"
  }
}
