{
  "name": "@fizmoo/core",
  "version": "0.1.4",
  "description": "The core library for building type-safe, self-documenting Node.js CLIs with fizmoo.",
  "homepage": "https://github.com/green-flash-digital/fizmoo#readme",
  "bugs": {
    "url": "https://github.com/green-flash-digital/fizmoo/issues"
  },
  "license": "Apache-2.0",
  "author": "Drew DeCarme (drew@greenflash.digital)",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/green-flash-digital/fizmoo.git",
    "directory": "packages/fizmoo-core"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js",
    "./runtime": "./dist/runtime/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "yarn tsc --project ./tsconfig.build.json",
    "dev": "yarn tsc --project ./tsconfig.build.json --watch"
  },
  "dependencies": {
    "@green-flash/ts-utils": "workspace:*",
    "@inquirer/prompts": "8.5.2",
    "dotdir": "0.4.7",
    "esbuild": "0.28.1",
    "isoscribe": "0.2.0",
    "picocolors": "1.1.1",
    "picomatch": "4.0.5",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@green-flash/tsconfig": "workspace:*",
    "@types/node": "26.1.1",
    "@types/picomatch": "4.0.3",
    "tsx": "4.23.0",
    "typescript": "6.0.3"
  }
}
