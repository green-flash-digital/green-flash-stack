{
  "$schema": "../../chamfer-core/src/schemas/tokens.schema.json",
  "runtime": {
    "prefix": "studio-dev",
    "strict": true,
    "suppressStrictWarnings": false
  },
  "sizeAndSpace": {
    "baseFontSize": 16,
    "baselineGrid": 4,
    "size": {
      "variants": {
        "xs": 24,
        "sm": 32,
        "md": 44,
        "lg": 56,
        "xl": 72
      }
    },
    "space": {
      "mode": "auto",
      "variants": 12
    }
  },
  "font": {
    "source": "manual",
    "families": {
      "inter": {
        "family": "Inter",
        "fallback": "system-ui, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\"",
        "styles": [
          "regular-400",
          "medium-500",
          "semiBold-600",
          "bold-700"
        ]
      },
      "playfair-display": {
        "family": "Playfair Display",
        "fallback": "system-ui, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\"",
        "styles": [
          "regular-400",
          "bold-700"
        ]
      }
    },
    "variants": {
      "body": {
        "familyToken": "inter",
        "weight": "400",
        "size": 16,
        "lineHeight": 1.5,
        "letterSpacing": 0
      },
      "heading-1": {
        "familyToken": "playfair-display",
        "weight": "700",
        "size": 48,
        "lineHeight": 1.1,
        "letterSpacing": -0.5
      },
      "heading-2": {
        "familyToken": "playfair-display",
        "weight": "700",
        "size": 36,
        "lineHeight": 1.2,
        "letterSpacing": -0.25
      },
      "label": {
        "familyToken": "inter",
        "weight": "500",
        "size": 14,
        "lineHeight": 1.4,
        "letterSpacing": 0
      }
    }
  },
  "response": {
    "breakpoints": {
      "mobile": 480,
      "tablet": 768,
      "laptop": 1024,
      "desktop": 1280,
      "ultraWide": 1536
    }
  },
  "color": {
    "vibe": {
      "type": "jewel",
      "lightness": 0.65,
      "chroma": 0.19
    },
    "colors": {
      "primary": {
        "hue": 220,
        "variants": 10
      },
      "secondary": {
        "hue": 160,
        "variants": 10
      },
      "tertiary": {
        "hue": 300,
        "variants": 10
      },
      "neutral-light": {
        "hex": "#cccccc",
        "variants": 10
      },
      "neutral-dark": {
        "hex": "#1a1b1e",
        "variants": 10
      }
    }
  },
  "semantic": {},
  "custom": {
    "layout-header-height": {
      "type": "rem",
      "value": 52,
      "description": "Height of the main navigation header"
    },
    "sidebar-width": {
      "type": "rem",
      "value": 240,
      "description": "Width of the sidebar navigation"
    }
  }
}
