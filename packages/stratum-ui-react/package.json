{
  "name": "@stratum-ui/react",
  "version": "0.1.0",
  "description": "UI components and utilities for stratum",
  "type": "module",
  "sideEffects": false,
  "author": "Drew DeCarme (drew@greenflash.digital)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/green-flash-digital/green-flash-stack.git",
    "directory": "packages/stratum-ui/react"
  },
  "bugs": {
    "url": "https://github.com/green-flash-digital/green-flash-stack/issues"
  },
  "homepage": "https://github.com/green-flash-digital/green-flash-stack#readme",
  "exports": {
    "./*": "./dist/*/index.js",
    "./css": "./dist/react.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build && yarn types",
    "dev": "vite build --watch",
    "types": "tsc --project tsconfig.build.json",
    "test": "vitest",
    "test:ci": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@green-flash/tsconfig": "workspace:*",
    "@linaria/core": "^6.3.0",
    "@storybook/react-vite": "^10.1.7",
    "@types/babel__core": "^7",
    "@types/node": "^25.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "4.0.15",
    "@wyw-in-js/vite": "^0.8.0",
    "eslint": "^9.39.1",
    "eslint-plugin-storybook": "^10.1.7",
    "storybook": "^10.1.7",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "@green-flash/reactor": "workspace:^",
    "@stratum-ui/core": "workspace:^",
    "react": "^19.2.2",
    "react-dom": "^19.2.2"
  }
}
