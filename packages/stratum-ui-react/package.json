{
  "name": "@stratum-ui/react",
  "version": "0.1.0",
  "description": "UI components and utilities for stratum",
  "homepage": "https://github.com/green-flash-digital/green-flash-stack#readme",
  "bugs": {
    "url": "https://github.com/green-flash-digital/green-flash-stack/issues"
  },
  "license": "Apache-2.0",
  "author": "Drew DeCarme (drew@greenflash.digital)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/green-flash-digital/green-flash-stack.git",
    "directory": "packages/stratum-ui/react"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./*": "./dist/*/index.js",
    "./css": "./dist/react.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && vite build && yarn types",
    "dev": "vite build --watch",
    "types": "tsc --project tsconfig.build.json",
    "test": "vitest",
    "test:ci": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@green-flash/reactor": "workspace:^",
    "@green-flash/ts-utils": "workspace:^",
    "@stratum-ui/core": "workspace:^",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-react": "^8.0.1",
    "@babel/preset-typescript": "^8.0.1",
    "@green-flash/tsconfig": "workspace:*",
    "@linaria/core": "^8.0.0",
    "@ngneat/falso": "^8.0.2",
    "@storybook/react-vite": "^10.4.6",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "4.1.9",
    "@wyw-in-js/vite": "^2.1.0",
    "storybook": "^10.4.6",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
