    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/preset-react": "8.0.1",
    "@babel/preset-typescript": "8.0.1",
    "@green-flash/tsconfig": "workspace:*",
    "@linaria/core": "8.0.0",
