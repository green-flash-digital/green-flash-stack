{
  "name": "documints",
  "version": "0.1.0",
  "description": "TODO",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "yarn typechecks && yarn lib:build && yarn fizmoo build",
    "dev": "yarn fizmoo dev",
    "typechecks": "tsc --project tsconfig.typechecks.json",
    "lib:build": "tsx ./scripts/lib.build.ts && yarn lib:types",
    "lib:types": "tsc --project tsconfig.library.types.json",
    "lib:dev": "yarn lib:build --watch",
    "pages:deploy": "cd ./.buttery/docs/dist && wrangler pages deploy ./build/client --project-name buttery-docs-cf",
    "pages:dev": "cd ./.buttery/docs/dist && wrangler pages dev ./build/client",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/green-flash-digital/green-flash-stack.git",
    "directory": "packages/documints"
  },
  "files": [
    "dist",
    "app",
    "bin"
  ],
  "author": "Drew DeCarme (drewdecarme@gmail.com)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/green-flash-digital/green-flash-stack/issues"
  },
  "homepage": "https://github.com/green-flash-digital/green-flash-stack#readme",
  "bin": "./bin/index.js",
  "exports": {
    "./server": "./dist/lib/server/index.js",
    "./server.dev": "./dist/lib/server.dev/index.js",
    "./server.cloudflare-pages": "./dist/lib/server.cloudflare-pages/index.js",
    "./client": "./dist/lib/client/index.js",
    "./plugin-interactive-preview": "./dist/lib/plugin-interactive-preview/vite/index.js",
    "./plugin-interactive-preview/ui": "./dist/lib/plugin-interactive-preview/ui/index.js",
    ".": "./dist/lib/index.js",
    "./app": "./dist/lib/app/index.js",
    "./css": "./dist/lib/style.css"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20250124.3",
    "@green-flash/tsconfig": "workspace:*",
    "@storybook/react": "8.5.2",
    "@types/babel__core": "7.20.5",
    "@types/express": "5.0.0",
    "@types/node": "22.12.0",
    "@types/react": "19.0.8",
    "@types/react-dom": "19.0.3",
    "@wyw-in-js/vite": "0.5.5",
    "rehype-parse": "9.0.1",
