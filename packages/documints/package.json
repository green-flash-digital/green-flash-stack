{
  "name": "documints",
  "version": "0.1.0",
  "description": "TODO",
  "homepage": "https://github.com/green-flash-digital/green-flash-stack#readme",
  "bugs": {
    "url": "https://github.com/green-flash-digital/green-flash-stack/issues"
  },
  "license": "MIT",
  "author": "Drew DeCarme (drewdecarme@gmail.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/green-flash-digital/green-flash-stack.git",
    "directory": "packages/documints"
  },
  "bin": "./bin/index.js",
  "files": [
    "dist",
    "bin"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "yarn lib:build && yarn fizmoo build",
    "dev": "yarn fizmoo dev",
    "docs:dev": "yarn build && yarn documints dev",
    "docs:build": "yarn build && yarn documints build",
    "lib:build": "tsc --project tsconfig.build.json",
    "typechecks": "tsc --project tsconfig.typechecks.json"
  },
  "dependencies": {
    "@documints/core": "workspace:*",
    "fizmoo": "workspace:*"
  },
  "devDependencies": {
    "@green-flash/tsconfig": "workspace:*",
    "@types/node": "26.1.1",
    "typescript": "6.0.3"
  }
}
