    "directory": "packages/documints"
  },
  "bin": "./bin/index.js",
  "files": [
    "dist",
    "bin"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js",
    "./plugins/interactive-preview": "./dist/plugins/interactive-preview/vite/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev:cli": "yarn fizmoo dev",
    "dev:docs": "yarn build:cli && yarn documints dev",
    "build": "yarn typechecks && yarn build:lib && yarn build:cli && yarn build:docs",
    "build:lib": "tsc --project tsconfig.build.json",
    "build:cli": "yarn fizmoo build",
    "build:docs": "yarn documints build",
    "deploy": "wrangler deploy",
    "typechecks": "tsc --project tsconfig.typechecks.json",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@babel/core": "8.0.1",
