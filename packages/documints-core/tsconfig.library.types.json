{
  "extends": "@green-flash/tsconfig/library",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "declarationDir": "dist",
    "emitDeclarationOnly": true
  },
  "include": [
    "src/server",
    "src/server.dev/index.ts",
    "src/server.static/index.ts",
    "src/plugin-interactive-preview",
    "app"
  ],
  "exclude": [
    "app/entry.client.tsx",
    "app/entry.server.tsx",
    "app/entry.server.static.tsx",
    "app/routes.ts"
  ]
}
