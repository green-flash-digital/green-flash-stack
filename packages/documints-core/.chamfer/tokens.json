{
  "$schema": "https://schemas.greenflash.digital/chamfer-tokens.json",
  "runtime": {
    "prefix": "documints",
    "strict": true,
    "suppressStrictWarnings": false
  },
  "sizeAndSpace": {
    "baseFontSize": 16,
    "baselineGrid": 4,
    "size": {
      "variants": {}
    },
    "space": {
      "mode": "auto",
      "variants": 10
    }
  },
  "font": {
    "source": "manual",
    "families": {
      "source-sans-3": {
        "family": "Source Sans 3",
        "fallback": "system-ui, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif, \"Apple Color Emoji\", \"Segoe UI Emoji\", \"Segoe UI Symbol\"",
        "styles": ["regular-400", "medium-500", "semiBold-600", "bold-700"]
      }
    },
    "variants": {}
  },
  "response": {
    "breakpoints": {
      "mobile": 480,
      "tablet": 768,
      "laptop": 1024,
      "desktop": 1280,
      "ultraWide": 1536
    }
  },
  "color": {
    "vibe": {
      "type": "fluorescent",
      "lightness": 0.825,
      "chroma": 0.23
    },
    "colors": {
      "primary": {
        "hue": 161,
        "variants": 10
      },
      "secondary": {
        "hue": 237,
        "variants": 10
      },
      "warning": {
        "hue": 56,
        "variants": 10
      },
      "danger": {
        "hue": 360,
        "variants": 10
      },
      "background": {
        "hex": "#ffffff",
        "variants": 0
      },
      "surface": {
        "hex": "#ffffff",
        "variants": 0
      },
      "neutral": {
        "hex": "#999999",
        "variants": 10
      }
    }
  },
  "semantic": {},
  "custom": {
    "layout-header-height": {
      "type": "rem",
      "value": 64,
      "description": "The height of the header in the layout"
    },
    "layout-max-width": {
      "type": "rem",
      "value": 1440,
      "description": "The max width that the layout of the docs can go"
    }
  }
}
