{
  "name": "logarhythm",
  "version": "0.0.1",
  "description": "An isomorphic logging utility for any JavaScript runtime, providing structured, styled, and extensible logs.",
  "keywords": [
    "console",
    "isomorphic",
    "logger",
    "logging",
    "structured-logging",
    "typescript"
  ],
  "homepage": "https://github.com/green-flash-digital/green-flash-stack#readme",
  "bugs": {
    "url": "https://github.com/green-flash-digital/green-flash-stack/issues"
  },
  "license": "Apache-2.0",
  "author": "Drew DeCarme (drew@greenflash.digital)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/green-flash-digital/green-flash-stack.git",
    "directory": "packages/logarhythm"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --project ./tsconfig.build.json",
    "dev": "yarn build --watch",
    "test": "yarn vitest",
    "test:ci": "yarn vitest --run",
    "preview": "yarn tsx ./scripts/sample.ts"
  },
  "dependencies": {
    "@green-flash/ts-utils": "workspace:*"
  },
  "devDependencies": {
    "@green-flash/tsconfig": "workspace:*",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
