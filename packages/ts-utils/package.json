{
  "name": "@green-flash/ts-utils",
  "version": "0.2.2",
  "description": "A collection of TypeScript tools, configs, and utilities that makes writing node, browser and isomorphic just a litttttttle bit easier",
  "homepage": "https://github.com/green-flash-digital/green-flash-stack#readme",
  "bugs": {
    "url": "https://github.com/green-flash-digital/green-flash-stack/issues"
  },
  "license": "Apache-2.0",
  "author": "Drew DeCarme (drew@greenflash.digital)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/green-flash-digital/green-flash-stack.git",
    "directory": "packages/ts-utils"
  },
  "files": [
    "dist",
    "tsconfigs"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./*": "./dist/*/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "yarn tsc --project tsconfig.build.json",
    "dev": "yarn build --watch",
    "test": "vitest",
    "test:ci": "vitest run"
  },
  "devDependencies": {
    "@green-flash/tsconfig": "workspace:*",
    "@types/node": "26.1.0",
    "@vitest/coverage-v8": "4.1.9",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
