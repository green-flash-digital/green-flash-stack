{
  "name": "@keystone-css/studio",
  "version": "0.3.6",
  "files": [
    "build",
    "StudioServer.js",
    "StudioServer.d.ts"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./server": "./StudioServer.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "react-router build && yarn server:build",
    "deploy": "wrangler pages deploy ./build/client",
    "dev": "NODE_ENV=development yarn tsx ./scripts/dev.ts",
    "dev:worker": "wrangler pages dev --compatibility-flag nodejs_compat",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "wrangler pages dev ./build/client",
    "typecheck": "react-router typegen && tsc",
    "typegen": "wrangler types",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "server:build": "yarn tsc --project tsconfig.server.json",
    "serve": "yarn tsx ./scripts/serve.ts"
  },
  "dependencies": {
    "@green-flash/ts-utils": "workspace:*",
    "@linaria/server": "8.0.0",
    "@monaco-editor/react": "4.7.0",
    "@react-router/cloudflare": "8.1.0",
    "@react-router/express": "8.1.0",
    "@react-router/node": "8.1.0",
    "@react-router/serve": "8.1.0",
    "chroma-js": "3.2.0",
    "express": "5.2.1",
    "immer": "11.1.9",
    "isbot": "5.1.44",
    "isoscribe": "0.2.0",
    "monaco-editor": "0.55.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-primitives": "workspace:*",
    "react-router": "8.1.0",
    "shiki": "4.3.0",
    "ts-pattern": "5.9.0",
    "use-immer": "0.11.0",
    "vite-plugin-monaco-editor": "1.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@babel/preset-react": "8.0.1",
    "@babel/preset-typescript": "8.0.1",
    "@chromatic-com/storybook": "5.2.1",
    "@gfdigital/tsconfig": "0.3.1",
    "@linaria/core": "8.0.0",
    "@react-router/dev": "8.1.0",
    "@storybook/addon-essentials": "8.6.14",
    "@storybook/addon-interactions": "8.6.14",
    "@storybook/addon-onboarding": "10.4.6",
    "@storybook/blocks": "8.6.14",
    "@storybook/react": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@storybook/test": "8.6.18",
    "@types/babel__core": "7.20.5",
    "@types/chroma-js": "3.1.2",
    "@types/express": "5.0.6",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@wyw-in-js/vite": "2.1.3",
    "eslint": "10.6.0",
    "react-router-devtools": "6.2.1",
    "storybook": "10.4.6",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "8.1.2",
    "wrangler": "4.106.0"
  }
}
